# Environment configuration for BUKZ Accounting
# Copy this file to .env.local and fill in the missing values

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
PORT=3000

# Database (PostgreSQL via Supabase or local Docker)
DATABASE_URL="postgresql://bukz:bukz_dev_password@localhost:5432/bukz_db"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Stripe Payments
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# AWS S3 Storage
AWS_S3_BUCKET="bukz-uploads"
# CLOUDFRONT_DOMAIN="d123456.cloudfront.net"

# Sentry
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="bukz-accounting"

# Vercel Deployment (Auto-populated by Vercel in production)
# VERCEL_URL="bukz.vercel.app"
